# /etc/nginx/sites-available/app-root
# vhost principal do site senado-nusp.cloud

# ---------- Upstream Django (Gunicorn) ----------
# Django está rodando em 127.0.0.1:8000 via systemd (senado-api.service)
# (conforme o plano de migração)  :contentReference[oaicite:1]{index=1}
upstream django_upstream {
    server 127.0.0.1:8000;
    keepalive 32;
}

# ---------- HTTP -> HTTPS (sem www) ----------
server {
    listen 80;
    listen [::]:80;
    server_name senado-nusp.cloud www.senado-nusp.cloud;
    return 301 https://senado-nusp.cloud$request_uri;
}

# ---------- WWW -> sem WWW (HTTPS) ----------
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name www.senado-nusp.cloud;

    ssl_certificate     /etc/letsencrypt/live/senado-nusp.cloud/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/senado-nusp.cloud/privkey.pem;

    return 301 https://senado-nusp.cloud$request_uri;
}

# ---------- HTTPS ----------
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name senado-nusp.cloud;

    # Certificados Let's Encrypt do domínio principal
    ssl_certificate     /etc/letsencrypt/live/senado-nusp.cloud/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/senado-nusp.cloud/privkey.pem;

    # Front-end estático
    root  /var/www/app;
    index index.html;

    # --- ANTI-CACHE: Força o navegador a sempre revalidar HTML/CSS/JS ---
    # O navegador verifica com o servidor se o arquivo mudou (via ETag/Last-Modified).
    # Se não mudou → 304 (rápido). Se mudou → baixa a versão nova.
    # A pasta /files/ não é afetada (tem seu próprio add_header que sobrescreve).
    add_header Cache-Control "no-cache, must-revalidate";

    # Cabeçalhos padrão de proxy (herdados pelas locations com proxy_pass)
    proxy_http_version 1.1;
    proxy_set_header Host               $host;
    proxy_set_header X-Real-IP          $remote_addr;
    proxy_set_header X-Forwarded-For    $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto  $scheme;
    proxy_set_header Connection         "";

    # Rotas do seu front (mantidas)
    location = /      { try_files /index.html =404; }
    location /imgs/   { try_files $uri        =404; }
    location = /home {
        auth_request /webhook/auth/html-guard;
        error_page 401 = /index.html;
        try_files /home.html =404;
    }
    location = /home.html {
        auth_request /webhook/auth/html-guard;
        error_page 401 = /index.html;
        try_files /home.html =404;
    }
    location /forms/ {
        auth_request /webhook/auth/html-guard;
        error_page 401 = /index.html;
        try_files $uri $uri/ =404;
    }
    location ^~ /admin/ {
        auth_request /webhook/auth/html-guard;
        error_page 401 = /index.html;
        try_files $uri $uri/ =404;
    }

    # ---------- Arquivos públicos (/files) ----------
    # Publica o diretório de uploads sob a URL /files/
    # Padrão do plano Django: FILES_DIR = /srv/senado/media   :contentReference[oaicite:2]{index=2}
    location ^~ /files/ {
        alias /var/lib/senado_nusp_prod/;
        autoindex off;
        try_files $uri =404;
        expires 30d;
        add_header Cache-Control "public, max-age=2592000";
    }

    # ---------- Backend API (catch-all /webhook/) ----------
    location /webhook/ {
        proxy_pass http://django_upstream;

        proxy_set_header Host               $host;
        proxy_set_header X-Real-IP          $remote_addr;
        proxy_set_header X-Forwarded-For    $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto  https;
    }
    
    # ---------- Proxy para Metabase ----------
    location ^~ /metabase/ {
        proxy_pass http://127.0.0.1:3000/;

        proxy_http_version 1.1;
        proxy_set_header Host               $host;
        proxy_set_header X-Real-IP          $remote_addr;
        proxy_set_header X-Forwarded-For    $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto  $scheme;
        proxy_set_header Connection         "";
    }
}